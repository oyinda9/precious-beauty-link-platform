model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  password           String
  fullName           String
  phone              String?
  role               UserRole            @default(CLIENT)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  bookings           Booking[]
  client             Client?
  receivedMessages   Message[]           @relation("receiver")
  sentMessages       Message[]           @relation("sender")
  reviews            Review[]
  salonAdmin         SalonAdmin?
  salonStaff         SalonStaff?
  superAdmin         SuperAdmin?
  passwordResetToken PasswordResetToken?
  auditLogs          AuditLog[]

  @@index([email])
  @@index([role])
}

model SuperAdmin {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Salon {
  id                   String             @id @default(cuid())
  name                 String
  slug                 String             @unique
  description          String?
  address              String
  city                 String
  state                String?
  zipCode              String?
  country              String?
  phone                String
  email                String
  website              String?
  latitude             Float?
  longitude            Float?
  rating               Float              @default(0)
  reviewCount          Int                @default(0)
  logoUrl              String?
  bannerUrl            String?
  isActive             Boolean            @default(true)
  subscriptionStatus   SubscriptionStatus @default(TRIAL)
  bankAccountName      String?
  bankAccountNumber    String?
  bankName             String?
  bankVerified         Boolean            @default(false)
  bankVerificationDate DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  bookings             Booking[]
  messages             Message[]
  revenue              Revenue[]
  reviews              Review[]
  admins               SalonAdmin[]
  staff                SalonStaff[]
  services             Service[]
  subscription         Subscription?
  timeSlots            TimeSlot[]

  @@index([slug])
  @@index([isActive])
  @@index([subscriptionStatus])
  @@index([bankVerified])
  @@index([bankVerificationDate])
}

model SalonAdmin {
  id        String   @id @default(cuid())
  userId    String   @unique
  salonId   String
  createdAt DateTime @default(now())
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([salonId])
}

model SalonStaff {
  id           String              @id @default(cuid())
  userId       String              @unique
  salonId      String
  specialties  String[]
  hourlyRate   Float?
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  bookings     Booking[]
  salon        Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability StaffAvailability[]

  @@index([salonId])
  @@index([isActive])
}

model Service {
  id          String    @id @default(cuid())
  salonId     String
  name        String
  description String?
  price       Float
  duration    Int
  category    String?
  image       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
  salon       Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([category])
}

model StaffAvailability {
  id        String     @id @default(cuid())
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  staff     SalonStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
}

model Booking {
  id            String        @id @default(cuid())
  clientId      String?
  clientPhone   String?
  salonId       String
  serviceId     String
  staffId       String?
  bookingDate   DateTime
  startTime     String
  endTime       String
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod String        @default("PAY_AT_SALON")
  notes         String?
  totalPrice    Float
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  client        User?         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  salon         Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  service       Service       @relation(fields: [serviceId], references: [id])
  staff         SalonStaff?   @relation(fields: [staffId], references: [id])
  payment       Payment?
  review        Review?

  @@index([clientId])
  @@index([salonId])
  @@index([staffId])
  @@index([status])
  @@index([bookingDate])
}

model Payment {
  id                      String        @id @default(cuid())
  bookingId               String        @unique
  amount                  Float
  currency                String        @default("NGN")
  externalPaymentId       String?
  paymentMethod           String        @default("BANK_TRANSFER")
  referenceNumber         String?       @unique
  bankTransferConfirmedAt DateTime?
  proofOfPayment          String?
  confirmationNotes       String?
  status                  PaymentStatus @default(PENDING)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  booking                 Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([externalPaymentId])
  @@index([referenceNumber])
  @@index([bankTransferConfirmedAt])
}

model AdminPaymentConfig {
  id                 String   @id @default(cuid())
  // Bank Transfer Details
  bankAccountName    String?
  bankAccountNumber  String?
  bankName           String?
  bankCode           String?
  // Card Payment Details
  cardHolderName     String?
  cardLastFour       String?
  cardBrand          String?  @default("VISA")
  // Settings
  acceptBankTransfer Boolean  @default(true)
  acceptCardPayment  Boolean  @default(true)
  paymentNote        String? // Instructions shown to users
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([isActive])
}

model Subscription {
  id                    String             @id @default(cuid())
  salonId               String             @unique
  plan                  SubscriptionPlan   @default(STARTER)
  status                SubscriptionStatus @default(TRIAL)
  stripeCustomerId      String?
  stripeSubId           String?
  reference             String?            @unique
  monthlyBookingLimit   Int                @default(30)
  bookingsUsedThisMonth Int                @default(0)
  bookingResetDate      DateTime           @default(now())
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  trialEndsAt           DateTime?
  cancelledAt           DateTime?
  paymentMethod         String?            @default("MONNIFY")
  manualPaymentProof    String?
  paymentVerifiedAt     DateTime?
  paymentVerifiedBy     String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  salon                 Salon              @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([reference])
  @@index([bookingResetDate])
}

model Revenue {
  id            String   @id @default(cuid())
  salonId       String
  amount        Float
  currency      String   @default("USD")
  month         Int
  year          Int
  totalBookings Int      @default(0)
  totalClients  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  salon         Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, month, year])
  @@index([salonId])
  @@index([year])
}

model Review {
  id        String   @id @default(cuid())
  salonId   String
  clientId  String
  bookingId String   @unique
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([clientId])
}

model TimeSlot {
  id        String   @id @default(cuid())
  salonId   String
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  salon     Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@index([salonId])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  salonId    String?
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  receiver   User     @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  salon      Salon?   @relation(fields: [salonId], references: [id])
  sender     User     @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([salonId])
}

model Client {
  id              String   @id @default(cuid())
  userId          String   @unique
  preferredSalons String[]
  totalSpent      Float    @default(0)
  totalBookings   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  SUPER_ADMIN
  SALON_ADMIN
  SALON_STAFF
  CLIENT
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PENDING_PAYMENT
  PAYMENT_REJECTED
  PAST_DUE
  CANCELLED
  SUSPENDED
}

enum BookingStatus {
  PENDING
  AWAITING_PAYMENT
  PAYMENT_SUBMITTED
  CONFIRMED
  PAID
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum SubscriptionPlan {
  FREE
  STARTER
  STANDARD
  GROWTH
  PREMIUM
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  actionType String
  entityType String
  entityId   String
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([actionType])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}
