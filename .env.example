# Example environment variables for local development and for Netlify
# Copy this file to `.env.local` for local dev (do not commit secrets)

# Postgres connection string (from Supabase or another hosted Postgres)
# Example: postgres://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL="postgres://USER:PASSWORD@HOST:PORT/DATABASE"

# JWT secret used by the server to sign tokens
JWT_SECRET="replace-with-a-long-random-string"

# Optional: Supabase client keys (if you use Supabase JS in frontend)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
# Database Configuration
# For Neon: postgresql://user:password@ep-xxxxx.region.neon.tech/salonbook?sslmode=require
# For local: postgresql://user:password@localhost:5432/salonbook
DATABASE_URL="postgresql://postgres:sholex972004@localhost:5432/salonbook"

# Authentication
# Generate a strong random string for this - at least 32 characters
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-minimum-32-chars"

# Environment
NODE_ENV="development"

# Analytics (Optional)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""
.p-