# Database Configuration
# For Neon: postgresql://user:password@ep-xxxxx.region.neon.tech/salonbook?sslmode=require
# For local: postgresql://user:password@localhost:5432/salonbook
DATABASE_URL="postgresql://user:password@localhost:5432/salonbook"

# Authentication
# Generate a strong random string for this - at least 32 characters
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-minimum-32-chars"

# Environment
NODE_ENV="development"

# Analytics (Optional)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=""
